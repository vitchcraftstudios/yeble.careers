{
  "name": "yeble-monorepo",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/mobile",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run postinstall --workspace apps/web",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:mobile": "npm run start --workspace apps/mobile",
    "lint:web": "npm run lint --workspace apps/web"
  }
}
